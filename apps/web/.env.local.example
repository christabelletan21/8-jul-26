NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-output-of-npx-auth-secret
INTERNAL_API_SECRET=replace-with-a-long-random-string-shared-with-api
EXPRESS_API_URL=http://localhost:4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sde_platform

# Optional: register a GitHub OAuth App (callback http://localhost:3000/api/auth/callback/github)
# to enable real GitHub sign-in. If left unset, only the dev login is shown.
GITHUB_ID=
GITHUB_SECRET=
